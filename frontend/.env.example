# ── Client / Tenant Configuration ────────────────────────────────────────
#
# Set VITE_CLIENT_ID to deploy the frontend with a specific client's branding.
# Available values: default | xiaomi | oppo | motorola | samsung | realme
#
# Example:  VITE_CLIENT_ID=xiaomi
#
VITE_CLIENT_ID=default

# ── Optional: show theme switcher in production ───────────────────────────
# In development (npm run dev) the theme switcher in the navbar is always visible.
# Set this to "true" to also show it in production builds (useful for demos).
#
VITE_SHOW_THEME_SWITCHER=false
