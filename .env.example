# ── Database (PostgreSQL) ──────────────────────────────────────────────
POSTGRES_DB=mysteryboxes
POSTGRES_USER=mbuser
POSTGRES_PASSWORD=changeme_in_production

# Full connection URL used by Flask (auto-built from above in docker-compose)
DATABASE_URL=postgresql://mbuser:changeme_in_production@db:5432/mysteryboxes

# ── Flask Backend ──────────────────────────────────────────────────────
FLASK_ENV=development
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-this-secret-key-in-production
JWT_SECRET_KEY=change-this-jwt-key-in-production

# ── Nginx ──────────────────────────────────────────────────────────────
NGINX_PORT=80

# ── Frontend (Vite) ────────────────────────────────────────────────────
VITE_API_BASE_URL=/api
