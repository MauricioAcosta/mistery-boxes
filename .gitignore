# ============================================================
#  MysteryBoxes — .gitignore
# ============================================================

# ── Secrets & environment ────────────────────────────────────
.env
*.env
!.env.example
!frontend/.env.example

# ── Python ──────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.so
*.egg
*.egg-info/
dist/
build/
eggs/
parts/
var/
sdist/
develop-eggs/
.installed.cfg
lib/
lib64/
MANIFEST

# Virtual environments
venv/
.venv/
env/
.env/
ENV/
env.bak/
venv.bak/

# Testing
.pytest_cache/
.coverage
coverage.xml
htmlcov/
.tox/
nosetests.xml
*.cover
*.log

# Type checkers & linters
.mypy_cache/
.dmypy.json
dmypy.json
.pyre/
.ruff_cache/

# ── Node / Frontend ──────────────────────────────────────────
node_modules/
frontend/node_modules/

# Build output
dist/
frontend/dist/
build/
frontend/build/
.next/
out/

# Vite
*.local
frontend/.vite/

# Package manager lockfiles (keep package-lock.json but ignore yarn/pnpm)
yarn.lock
pnpm-lock.yaml
.pnp.*
.yarn/

# ── Docker ───────────────────────────────────────────────────
# Keep Dockerfiles and docker-compose.yml
# Ignore local override files
docker-compose.override.yml
docker-compose.local.yml

# ── IDE & editors ────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# Claude Code
.claude/

# ── Database ─────────────────────────────────────────────────
*.sqlite3
*.db
*.sql.gz
pgdata/

# ── Logs ─────────────────────────────────────────────────────
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pids/
*.pid
*.seed
*.pid.lock

# ── Misc ─────────────────────────────────────────────────────
*.bak
*.tmp
*.temp
.cache/
